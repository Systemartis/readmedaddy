{
  "_README": "Copy this file to your repo root as .readmedaddy.json (drop the .example) to configure the readmedaddy readme-drift Stop hook. All fields are optional; omit any key to keep its default. JSON has no comments, so this _README field carries the docs. The hook detects when watched signal files changed but your README did not, then prompts an in-session refresh through the readmedaddy skill -- it never rewrites files on its own. mode is auto (block once per drift, default) | notify (stderr only, non-blocking) | enforce (re-prompt every Stop until the README changes). Force a mode for one session with README_DADDY_HOOK=auto|notify|enforce, or disable with README_DADDY_HOOK=off. Full docs: skills/readmedaddy/references/auto-update-hook.md",
  "hook": {
    "enabled": true,
    "mode": "auto",
    "readme": "README.md",
    "watch": [
      "package.json",
      "pyproject.toml",
      "Cargo.toml",
      "go.mod",
      "go.sum",
      "Gemfile",
      "composer.json",
      "build.gradle",
      "pom.xml",
      "bin/**",
      "src/**",
      "cmd/**",
      "cli/**",
      ".github/workflows/**",
      "install.sh",
      "Makefile",
      "Dockerfile",
      "docker-compose.yml",
      "**/SKILL.md"
    ]
  }
}
